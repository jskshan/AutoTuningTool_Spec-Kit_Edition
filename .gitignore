# =============================================================================
# AutoTuningTool .gitignore
# Visual Studio / C# / .NET Framework 專案
# =============================================================================

# -----------------------------------------------------------------------------
# 建置結果
# -----------------------------------------------------------------------------
# obj、Log 目錄完全忽略（內容無需追蹤）
[Oo]bj/
[Ll]og/
[Ll]ogs/

# 根目錄層級的平台/組態資料夾（加 / 前綴，限根目錄，避免影響 bin 內同名子目錄）
/[Dd]ebug/
/[Dd]ebugPublic/
/[Rr]elease/
/[Rr]eleases/
/x64/
/x86/
/[Ww][Ii][Nn]32/
/[Aa][Rr][Mm]/
/[Aa][Rr][Mm]64/
/bld/

# Release_9F07_Socket 建置輸出（根目錄層級）
/Release_9F07_Socket/

# bin 目錄：依副檔名忽略編譯產物
# 重要：改用 ** 路徑模式（而非 [Bb]in/ 目錄模式），使下方 ! negation 白名單得以生效
**/bin/**/*.exe
**/bin/**/*.lib
**/bin/**/*.pdb
**/bin/**/*.xml
**/bin/**/*.manifest
**/bin/**/*.application
**/bin/**/app.publish/
**/bin/**/*.txt
**/bin/**/*.csv

# MPP Pen 與 Finger 觸控調校工具的核心 DLL（執行期必要資源）
**/bin/**/FingerAutoTuning.dll
**/bin/**/MPPPenAutoTuning.dll

# -----------------------------------------------------------------------------
# bin 執行期資源白名單
# 此區段必須位於上方所有 bin 忽略規則之後，negation 才能正確覆蓋
# -----------------------------------------------------------------------------
# Finger 觸控調校設定檔與圖示
!**/bin/**/Finger/
!**/bin/**/Finger/**
# Finger 目錄內的 .txt / .csv 仍忽略
**/bin/**/Finger/**/*.txt
**/bin/**/Finger/**/*.csv

# MPP Pen 調校設定、命令腳本與流程定義
!**/bin/**/MPP Pen/
!**/bin/**/MPP Pen/**
# MPP Pen 目錄內的 .txt / .csv 仍忽略
**/bin/**/MPP Pen/**/*.txt
**/bin/**/MPP Pen/**/*.csv

# Android 遠端連線工具（RemoteClient / RemoteClient_Org）
!**/bin/**/RemoteClient*/
!**/bin/**/RemoteClient*/**

# HDF5 格式轉換工具（Python 3.7 嵌入式環境）
!**/bin/**/HDF5ConvertTool/
!**/bin/**/HDF5ConvertTool/**

# Android Touch Agent（含 aarch64/arm/x86 子目錄）
!**/bin/**/touch_data_agent*/
!**/bin/**/touch_data_agent*/**

# EDID 讀取工具（執行期輔助程式）
!**/bin/**/GetEDID.exe

